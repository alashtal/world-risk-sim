        <header className="header">
          <div className="logo">GLOBAL<span>RISK</span>SIM <span style={{ color: "#3d5a7a", fontSize: 11 }}>// v2.6.1</span></div>
          <div className="status-bar">
            <span><span className="status-dot" />LIVE ANALYSIS</span>
            <span style={{ color: "#2a3d52" }}>FRAME {(tick * 1247 + 8391) % 99999}</span>
            <span style={{ color: "#2a3d52" }}>SYS: NOMINAL</span>
          </div>
        </header>

        <nav className="tabs">
          {tabs.map(t => (
            <button key={t.id} className={`tab-btn ${tab === t.id ? "active" : ""}`} onClick={() => setTab(t.id)}>
              {t.label}
            </button>
          ))}
        </nav>

        <div className="content">

          {/* ── OVERVIEW ── */}
          {tab === "overview" && (
            <>
              <p className="section-title">Multi-Method Consensus Estimate</p>

              <div style={{ marginBottom: 20 }}>
                <div className="horizon-bar">
                  {["10", "30", "50"].map(h => (
                    <button key={h} className={`hz-btn ${horizon === h ? "active" : ""}`} onClick={() => setHorizon(h)}>
                      {h}-YR
                    </button>
                  ))}
                </div>
              </div>

              <div className="consensus-banner">
                <div className="cb-item">
                  <div className="cb-label">WORLD WAR · {horizon}yr</div>
                  <div className="cb-val" style={{ color: warColor }}>{warPct}%</div>
                </div>
                <div style={{ width: 1, background: "#0f1e30" }} />
                <div className="cb-item">
                  <div className="cb-label">ECON CRASH · {horizon}yr</div>
                  <div className="cb-val" style={{ color: crashColor }}>{crashPct}%</div>
                </div>
                <div style={{ width: 1, background: "#0f1e30" }} />
                <div className="cb-item">
                  <div className="cb-label">COMBINED RISK</div>
                  <div className="cb-val" style={{ color: "#ff3b5c" }}>
                    {Math.round(100 - (1 - warPct / 100) * (1 - crashPct / 100) * 100)}%
                  </div>
                </div>
                <div style={{ width: 1, background: "#0f1e30" }} />
                <div className="cb-item">
                  <div className="cb-label">METHODS USED</div>
                  <div className="cb-val" style={{ color: "#7aafd4" }}>6</div>
                </div>
              </div>

              <div className="grid-2">
                <div className="card">
                  <div className="card-title">WORLD WAR III PROBABILITY</div>
                  <div style={{ display: "flex", alignItems: "flex-end", gap: 16 }}>
                    <div>
                      <div className="big-pct" style={{ color: warColor }}>{warPct}<span style={{ fontSize: 24 }}>%</span></div>
                      <div className="pct-label">Within {horizon} years</div>
                    </div>
                    <div style={{ flex: 1 }}>
                      <GaugeArc pct={warPct} color={warColor} size={130} />
                    </div>
                  </div>
                  <div style={{ marginTop: 16 }}>
                    {WAR_METHODS.map(m => (
                      <div className="progress-wrap" key={m.id}>
                        <div className="progress-label">
                          <span>{m.label}</span>
                          <span style={{ color: "#7aafd4" }}>{m[`war${horizon}`]}%</span>
                        </div>
                        <div className="progress-track">
                          <div className="progress-fill" style={{
                            width: `${m[`war${horizon}`]}%`,
                            background: `linear-gradient(90deg, #00b4ff, ${m[`war${horizon}`] > 35 ? "#ff3b5c" : "#00b4ff"})`,
                          }} />
                        </div>
                      </div>
                    ))}
                  </div>
                  <div className="note-box" style={{ marginTop: 14 }}>
                    ⚠ Nuclear deterrence significantly suppresses near-term probability. Tail risks spike post-30yr due to regime changes, AI autonomy, and proliferation.
                  </div>
                </div>

                <div className="card">
                  <div className="card-title">GLOBAL ECONOMIC CRASH PROBABILITY</div>
                  <div style={{ display: "flex", alignItems: "flex-end", gap: 16 }}>
                    <div>
                      <div className="big-pct" style={{ color: crashColor }}>{crashPct}<span style={{ fontSize: 24 }}>%</span></div>
                      <div className="pct-label">Within {horizon} years</div>
                    </div>
                    <div style={{ flex: 1 }}>
                      <GaugeArc pct={crashPct} color={crashColor} size={130} />
                    </div>
                  </div>
                  <div style={{ marginTop: 16 }}>
                    {WAR_METHODS.map(m => (
                      <div className="progress-wrap" key={m.id}>
                        <div className="progress-label">
                          <span>{m.label}</span>
                          <span style={{ color: "#f5c518" }}>{m[`crash${horizon}`]}%</span>
                        </div>
                        <div className="progress-track">
                          <div className="progress-fill" style={{
                            width: `${m[`crash${horizon}`]}%`,
                            background: `linear-gradient(90deg, #f5c518, ${m[`crash${horizon}`] > 70 ? "#ff3b5c" : "#f5c518"})`,
                          }} />
                        </div>
                      </div>
                    ))}
                  </div>
                  <div className="note-box" style={{ borderColor: "#f5c518", marginTop: 14 }}>
                    ⚠ Economic crash probability is substantially higher — near-certainty at 50yr horizon due to compounding debt cycles, dollar hegemony erosion & trade fragmentation.
                  </div>
                </div>
              </div>
            </>
          )}

          {/* ── METHODS ── */}
          {tab === "methods" && (
            <>
              <p className="section-title">Estimation Methodology Breakdown</p>
              <div className="horizon-bar">
                {["10", "30", "50"].map(h => (
                  <button key={h} className={`hz-btn ${horizon === h ? "active" : ""}`} onClick={() => setHorizon(h)}>
                    {h}-YEAR HORIZON
                  </button>
                ))}
              </div>
              <div className="grid-2">
                <div className="method-list">
                  {WAR_METHODS.map((m, i) => (
                    <div key={m.id} className={`method-item ${activeMethod === i ? "active" : ""}`} onClick={() => setActiveMethod(i)}>
                      <div className="method-name">{m.label}</div>
                      <div className="method-desc">{m.desc.slice(0, 90)}…</div>
                    </div>
                  ))}
                </div>
                <div className="card">
                  <div className="card-title">{m.label.toUpperCase()}</div>
                  <div className="method-desc" style={{ color: "#7aafd4", fontSize: 14, lineHeight: 1.6 }}>{m.desc}</div>
                  <div className="result-row">
                    <div>
                      <div style={{ fontFamily: "'Orbitron'", fontSize: 10, letterSpacing: 1.5, color: "#3d5a7a", marginBottom: 8 }}>WORLD WAR</div>
                      <div className="result-box">
                        <div className="result-num" style={{ color: "#00b4ff" }}>{m[`war${horizon}`]}%</div>
                        <div className="result-sub">{horizon}-YEAR</div>
                      </div>
                    </div>
                    <div>
                      <div style={{ fontFamily: "'Orbitron'", fontSize: 10, letterSpacing: 1.5, color: "#3d5a7a", marginBottom: 8 }}>ECON CRASH</div>
                      <div className="result-box">
                        <div className="result-num" style={{ color: "#f5c518" }}>{m[`crash${horizon}`]}%</div>
                        <div className="result-sub">{horizon}-YEAR</div>
                      </div>
                    </div>
                  </div>
                  <div className="note-box">{m.note}</div>
                  <div style={{ marginTop: 20 }}>
                    <div className="card-title">ALL HORIZONS</div>
                    {[["10", "War"], ["30", "War"], ["50", "War"], ["10", "Crash"], ["30", "Crash"], ["50", "Crash"]].map(([h, type]) => (
                      <div className="progress-wrap" key={h + type}>
                        <div className="progress-label">
                          <span>{type} · {h}yr</span>
                          <span style={{ color: type === "War" ? "#00b4ff" : "#f5c518" }}>{m[`${type.toLowerCase()}${h}`]}%</span>
                        </div>
                        <div className="progress-track">
                          <div className="progress-fill" style={{
                            width: `${m[`${type.toLowerCase()}${h}`]}%`,
                            background: type === "War" ? "#00b4ff" : "#f5c518",
                          }} />
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </>
          )}

          {/* ── GAME THEORY ── */}
          {tab === "gametheory" && (
            <>
              <p className="section-title">Game Theory — Payoff Matrix Analysis</p>
              <div style={{ marginBottom: 16, padding: "12px 16px", background: "rgba(245,197,24,0.04)", border: "1px solid rgba(245,197,24,0.15)", borderRadius: 3, fontSize: 13, color: "#9aad6a", lineHeight: 1.7 }}>
                <strong style={{ color: "#f5c518", fontFamily: "'Orbitron'", fontSize: 10, letterSpacing: 1.5 }}>METHODOLOGY</strong><br />
                Each cell shows payoffs as <span style={{ fontFamily: "'Share Tech Mono'" }}>(Actor 1, Actor 2)</span> on a scale of –5 (catastrophic) to +5 (optimal). Nash Equilibria (★NE) are cells where no actor can unilaterally improve their outcome. Payoff format: <span style={{ fontFamily: "'Share Tech Mono'", color: "#00ff9d" }}>(+3, +3)</span> = mutual gain, <span style={{ fontFamily: "'Share Tech Mono'", color: "#ff3b5c" }}>(-5, -5)</span> = mutual destruction.
              </div>

              <div className="scenario-tabs">
                {GT_SCENARIOS.map((s, i) => (
                  <button key={i} className={`sc-btn ${activeScenario === i ? "active" : ""}`} onClick={() => setActiveScenario(i)}>
                    {s.label}
                  </button>
                ))}
              </div>

              {(() => {
                const sc = GT_SCENARIOS[activeScenario];
                const [a1, a2] = sc.actors;
                return (
                  <div className="card">
                    <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
                      <div className="card-title">{sc.label}</div>
                      <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                        <span style={{ fontFamily: "'Share Tech Mono'", fontSize: 11, color: "#3d5a7a" }}>TENSION INDEX</span>
                        <span style={{ fontFamily: "'Orbitron'", fontSize: 16, fontWeight: 700, color: sc.risk > 60 ? "#ff3b5c" : "#f5c518" }}>{sc.risk}%</span>
                      </div>
                    </div>
                    <div className="matrix-wrap">
                      <table className="payoff">
                        <thead>
                          <tr>
                            <th></th>
                            <th colSpan={2} style={{ color: "#f5c518" }}>{a2}</th>
                          </tr>
                          <tr>
                            <th style={{ color: "#00b4ff" }}>{a1}</th>
                            <th>COOPERATE / DETER</th>
                            <th>ESCALATE / DEFECT</th>
                          </tr>
                        </thead>
                        <tbody>
                          <tr>
                            <td className="row-header">COOPERATE / DETER</td>
                            <MatrixCell data={sc.matrix[0][0]} isNash={true} />
                            <MatrixCell data={sc.matrix[0][1]} isNash={false} />
                          </tr>
                          <tr>
                            <td className="row-header">ENGAGE / DEFECT</td>
                            <MatrixCell data={sc.matrix[1][0]} isNash={false} />
                            <MatrixCell data={sc.matrix[1][1]} isNash={false} />
                          </tr>
                        </tbody>
                      </table>
                    </div>
                    <div className="nash-desc">
                      <strong style={{ color: "#f5c518", fontFamily: "'Orbitron'", fontSize: 9, letterSpacing: 1.5 }}>★ NASH EQUILIBRIUM ANALYSIS</strong><br />
                      {sc.nash}
                    </div>
                    <div style={{ marginTop: 20 }}>
                      <div className="card-title">KEY GAME THEORY INSIGHTS</div>
                      <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                        {[
                          ["Commitment Problems", "States cannot credibly commit to future restraint → arms races & first-mover advantage logic prevail"],
                          ["Information Asymmetry", "Incomplete intelligence creates miscalculation risk — adversaries may misread capability/intent"],
                          ["Iterated vs. One-Shot", "Repeated interaction enables cooperation norms (MAD), but leadership transitions reset the game"],
                          ["Coalition Dynamics", "Multi-actor settings (US, China, Russia, EU, India) create alliance formation games where minor shifts cascade"],
                        ].map(([title, body]) => (
                          <div key={title} style={{ padding: "10px 14px", background: "#0a1018", border: "1px solid #0f1e30", borderRadius: 3 }}>
                            <div style={{ fontFamily: "'Orbitron'", fontSize: 9, letterSpacing: 1.5, color: "#00b4ff", marginBottom: 4 }}>{title}</div>
                            <div style={{ fontSize: 12, color: "#5a7a9a", lineHeight: 1.6 }}>{body}</div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                );
              })()}
            </>
          )}

          {/* ── RISK FACTORS ── */}
          {tab === "factors" && (
            <>
              <p className="section-title">Geopolitical & Economic Risk Indicators</p>
              <div className="grid-2">
                <div className="card">
                  <div className="card-title">WAR RISK FACTORS</div>
                  <div className="risk-grid">
                    {RISK_FACTORS.filter(r => r.type === "war").map(r => {
                      const c = r.val > 70 ? "#ff3b5c" : r.val > 50 ? "#f5c518" : "#00ff9d";
                      return (
                        <div className="risk-row" key={r.label}>
                          <div className="risk-name">{r.label}</div>
                          <div className="risk-bar-track">
                            <div className="risk-bar-fill" style={{ width: `${r.val}%`, background: `linear-gradient(90deg, ${c}44, ${c})`, boxShadow: `0 0 8px ${c}44` }} />
                          </div>
                          <div className="risk-val" style={{ color: c }}>{r.val}</div>
                        </div>
                      );
                    })}
                  </div>
                </div>
                <div className="card">
                  <div className="card-title">ECONOMIC CRASH FACTORS</div>
                  <div className="risk-grid">
                    {RISK_FACTORS.filter(r => r.type === "crash").map(r => {
                      const c = r.val > 70 ? "#ff3b5c" : r.val > 50 ? "#f5c518" : "#00ff9d";
                      return (
                        <div className="risk-row" key={r.label}>
                          <div className="risk-name">{r.label}</div>
                          <div className="risk-bar-track">
                            <div className="risk-bar-fill" style={{ width: `${r.val}%`, background: `linear-gradient(90deg, ${c}44, ${c})`, boxShadow: `0 0 8px ${c}44` }} />
                          </div>
                          <div className="risk-val" style={{ color: c }}>{r.val}</div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
              <div style={{ marginTop: 20 }}>
                <div className="card">
                  <div className="card-title">CASCADING RISK TOPOLOGY</div>
                  <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
                    {[
                      { from: "Trade War", to: "Supply Shock", color: "#f5c518" },
                      { from: "Supply Shock", to: "Inflation Spiral", color: "#f5c518" },
                      { from: "Inflation Spiral", to: "Debt Crisis", color: "#ff3b5c" },
                      { from: "Debt Crisis", to: "Banking Collapse", color: "#ff3b5c" },
                      { from: "Banking Collapse", to: "Depression", color: "#ff3b5c" },
                      { from: "Depression", to: "Political Instability", color: "#ff3b5c" },
                      { from: "Political Instability", to: "Armed Conflict", color: "#ff3b5c" },
                    ].map((e, i) => (
                      <div key={i} style={{ display: "flex", alignItems: "center", gap: 6 }}>
                        <span style={{ fontFamily: "'Share Tech Mono'", fontSize: 11, color: e.color }}>{e.from}</span>
                        <span style={{ color: "#2a3d52" }}>→</span>
                        <span style={{ fontFamily: "'Share Tech Mono'", fontSize: 11, color: e.color }}>{e.to}</span>
                      </div>
                    ))}
                  </div>
                  <div className="note-box" style={{ marginTop: 14 }}>
                    Historical pattern: economic crises precede major conflicts with 70%+ frequency. The 1929 crash → WWII pathway is the canonical modern example.
                  </div>
                </div>
              </div>
            </>
          )}

          {/* ── SIMULATION ── */}
          {tab === "sim" && (
            <>
              <p className="section-title">Monte Carlo Simulation — 40-Run Sample</p>
              <div className="card">
                <div className="card-title">STOCHASTIC VARIABLE SET (14 INPUTS)</div>
                <div style={{ display: "flex", flexWrap: "wrap", gap: 8, marginBottom: 16 }}>
                  {["US-China Tension", "NATO Cohesion", "Nuclear Accident P", "Climate Shocks", "Debt/GDP Ratio", "Dollar Index", "Asset Valuations", "Supply Chain Stress", "Political Polarization", "AI Autonomy Level", "Energy Price Volatility", "Food Security", "Pandemic Risk", "Space/Cyber Conflict"].map(v => (
                    <span key={v} style={{ fontFamily: "'Share Tech Mono'", fontSize: 10, color: "#3d5a7a", padding: "3px 8px", border: "1px solid #0f1e30", borderRadius: 2 }}>{v}</span>
                  ))}
                </div>
                <div style={{ marginBottom: 8, fontFamily: "'Share Tech Mono'", fontSize: 11, color: "#3d5a7a" }}>
                  Each dot = one simulation run. Color = outcome severity.
                  <span style={{ marginLeft: 16, color: "#00ff9d" }}>■ LOW</span>
                  <span style={{ marginLeft: 12, color: "#f5c518" }}>■ MED</span>
                  <span style={{ marginLeft: 12, color: "#ff3b5c" }}>■ HIGH</span>
                </div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16 }}>
                  <div>
                    <div style={{ fontFamily: "'Orbitron'", fontSize: 9, letterSpacing: 1.5, color: "#00b4ff", marginBottom: 8 }}>WAR OUTCOMES</div>
                    <div className="sim-grid">
                      {simResults.map((r, i) => {
                        const v = parseFloat(r.war);
                        const c = v < 20 ? "#00ff9d" : v < 50 ? "#f5c518" : "#ff3b5c";
                        return <div key={i} className="sim-dot" style={{ background: c + "33", border: `1px solid ${c}`, boxShadow: `0 0 4px ${c}44` }} title={`${v}%`} />;
                      })}
                      {simRunning && <div className="sim-dot" style={{ background: "#00b4ff22", border: "1px solid #00b4ff", animation: "blink 0.4s infinite" }} />}
                    </div>
                    {simResults.length > 0 && (
                      <div style={{ marginTop: 10, fontFamily: "'Orbitron'", fontSize: 13, color: "#00b4ff" }}>
                        AVG: {(simResults.reduce((s, r) => s + parseFloat(r.war), 0) / simResults.length).toFixed(1)}%
                      </div>
                    )}
                  </div>
                  <div>
                    <div style={{ fontFamily: "'Orbitron'", fontSize: 9, letterSpacing: 1.5, color: "#f5c518", marginBottom: 8 }}>CRASH OUTCOMES</div>
                    <div className="sim-grid">
                      {simResults.map((r, i) => {
                        const v = parseFloat(r.crash);
                        const c = v < 30 ? "#00ff9d" : v < 60 ? "#f5c518" : "#ff3b5c";
                        return <div key={i} className="sim-dot" style={{ background: c + "33", border: `1px solid ${c}`, boxShadow: `0 0 4px ${c}44` }} title={`${v}%`} />;
                      })}
                      {simRunning && <div className="sim-dot" style={{ background: "#f5c51822", border: "1px solid #f5c518", animation: "blink 0.4s infinite" }} />}
                    </div>
                    {simResults.length > 0 && (
                      <div style={{ marginTop: 10, fontFamily: "'Orbitron'", fontSize: 13, color: "#f5c518" }}>
                        AVG: {(simResults.reduce((s, r) => s + parseFloat(r.crash), 0) / simResults.length).toFixed(1)}%
                      </div>
                    )}
                  </div>
                </div>
                <button className="run-btn" onClick={runSim} disabled={simRunning}>
                  {simRunning ? "RUNNING..." : "▶ RUN SIMULATION"}
                </button>
              </div>

              <div className="card" style={{ marginTop: 16 }}>
                <div className="card-title">FINAL WEIGHTED CONSENSUS — ALL METHODS</div>
                <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 12, marginTop: 8 }}>
                  {["10", "30", "50"].map(h => (
                    <div key={h} style={{ textAlign: "center", padding: "16px 12px", background: "#0a1018", border: "1px solid #0f1e30", borderRadius: 3 }}>
                      <div style={{ fontFamily: "'Orbitron'", fontSize: 9, letterSpacing: 2, color: "#3d5a7a", marginBottom: 10 }}>{h}-YEAR</div>
                      <div style={{ fontFamily: "'Orbitron'", fontSize: 20, fontWeight: 700, color: "#00b4ff", marginBottom: 4 }}>{WEIGHTED_AVG[`war${h}`]}%</div>
                      <div style={{ fontFamily: "'Share Tech Mono'", fontSize: 10, color: "#3d5a7a", marginBottom: 10 }}>World War</div>
                      <div style={{ height: 1, background: "#0f1e30", margin: "8px 0" }} />
                      <div style={{ fontFamily: "'Orbitron'", fontSize: 20, fontWeight: 700, color: "#f5c518", marginBottom: 4 }}>{WEIGHTED_AVG[`crash${h}`]}%</div>
                      <div style={{ fontFamily: "'Share Tech Mono'", fontSize: 10, color: "#3d5a7a" }}>Econ Crash</div>
                    </div>
                  ))}
                </div>
              </div>
            </>
          )}

          <div className="disclaimer">
            ⚠ ANALYTICAL DISCLAIMER — This simulation is a conceptual probability model for intellectual exploration only. Figures are synthesized from academic literature, prediction market data, and game-theoretic models as of early 2026. No model can reliably predict complex geopolitical events. This is NOT financial, strategic, or policy advice. Probabilities are inherently uncertain and model-dependent. Real-world outcomes are shaped by human agency, leadership decisions, and emergent events that cannot be fully captured quantitatively.
          </div>

        </div>
      </div>
    </>
  );
}

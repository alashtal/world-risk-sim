  },
  {
    id: "montecarlo",
    label: "Monte Carlo Simulation",
    desc: "10,000 runs across 14 stochastic variables: US-China tension, NATO cohesion, nuclear accidents, climate shocks, debt spirals, currency crises.",
    war10: 9, war30: 24, war50: 37,
    crash10: 52, crash30: 84, crash50: 96,

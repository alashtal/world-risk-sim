      [{ label: "USA: Open", payoff: [4, 4], opp: [4, 4] }, { label: "USA: Open", payoff: [-2, 6], opp: [6, -1] }],
      [{ label: "USA: Tariffs", payoff: [5, -1], opp: [-1, 5] }, { label: "USA: Tariffs", payoff: [1, 1], opp: [1, 1] }],
    ],
    nash: "Classic Prisoner's Dilemma. Nash Eq = mutual tariffs (1,1) even though mutual openness (4,4) is Pareto superior. Cooperation requires binding enforcement.",
    risk: 75,
  },
];

const RISK_FACTORS = [
  { label: "US–China Rivalry", val: 78, type: "war" },
  { label: "Russia–NATO Tension", val: 65, type: "war" },

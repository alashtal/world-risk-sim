  const [simRunning, setSimRunning] = useState(false);
  const [simResults, setSimResults] = useState([]);
  const [tick, setTick] = useState(0);
  const intervalRef = useRef(null);

  useEffect(() => {
    const t = setInterval(() => setTick(x => x + 1), 1200);
    return () => clearInterval(t);
  }, []);

  const runSim = () => {
    setSimRunning(true);
    setSimResults([]);
    let i = 0;
    intervalRef.current = setInterval(() => {
      const war = Math.random() * 100;
      const crash = Math.random() * 100;
      setSimResults(prev => [...prev.slice(-39), { war: war.toFixed(1), crash: crash.toFixed(1), id: i }]);
      i++;
      if (i >= 40) {
        clearInterval(intervalRef.current);
        setSimRunning(false);
      }
    }, 80);
  };

  const m = WAR_METHODS[activeMethod];
  const hKey = `war${horizon}`;
  const cKey = `crash${horizon}`;
  const warPct = WEIGHTED_AVG[`war${horizon}`];

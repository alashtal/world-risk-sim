    crash10: 42, crash30: 70, crash50: 88,
    note: "Markets underweight tail risks historically; adjust upward for black swan exposure",
  },
  {
    id: "gametheory",
    label: "Game Theory (Nash Eq.)",
    desc: "Multi-player iterated game across US, China, Russia, EU, India. Mixed strategy equilibria under incomplete information & commitment problems.",
    war10: 14, war30: 31, war50: 44,
    crash10: 50, crash30: 80, crash50: 94,
    note: "Commitment problems & first-mover advantages elevate war risk vs. cooperative outcome",
  },
];

const WEIGHTED_AVG = {
  war10: Math.round(WAR_METHODS.reduce((s, m) => s + m.war10, 0) / WAR_METHODS.length),
  war30: Math.round(WAR_METHODS.reduce((s, m) => s + m.war30, 0) / WAR_METHODS.length),
  war50: Math.round(WAR_METHODS.reduce((s, m) => s + m.war50, 0) / WAR_METHODS.length),
  crash10: Math.round(WAR_METHODS.reduce((s, m) => s + m.crash10, 0) / WAR_METHODS.length),
  crash30: Math.round(WAR_METHODS.reduce((s, m) => s + m.crash30, 0) / WAR_METHODS.length),
  crash50: Math.round(WAR_METHODS.reduce((s, m) => s + m.crash50, 0) / WAR_METHODS.length),
};

// Nash equilibrium payoff matrices
const GT_ACTORS = ["USA", "China", "Russia", "EU", "India"];

// War/Cooperation payoff matrix (rows = actor strategy, cols = opponent avg response)
// Values: [cooperate_payoff, defect_payoff] for each actor pair
const GT_SCENARIOS = [
  {
    label: "US–China: Taiwan Strait",
    actors: ["USA", "China"],
    matrix: [
      // China: Cooperate, China: Escalate
      [{ label: "USA: Deter", payoff: [3, 3], opp: [2, 2] }, { label: "USA: Deter", payoff: [1, -4], opp: [-3, 5] }],

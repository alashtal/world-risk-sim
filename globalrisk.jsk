];

// ─── COMPONENTS ──────────────────────────────────────────────────────────────

function GaugeArc({ pct, color, size = 120 }) {
  const r = size * 0.38;
  const cx = size / 2, cy = size / 2 + size * 0.05;
  const sweep = Math.PI;
  const startAngle = Math.PI;
  const endAngle = Math.PI + sweep * (pct / 100);
  const x1 = cx + r * Math.cos(startAngle);
  const y1 = cy + r * Math.sin(startAngle);
  const x2 = cx + r * Math.cos(endAngle);
  const y2 = cy + r * Math.sin(endAngle);
  const lg = endAngle - startAngle > Math.PI ? 1 : 0;

  return (
    <svg width={size} height={size * 0.62} viewBox={`0 0 ${size} ${size * 0.62}`}>
      <path
        d={`M ${cx - r} ${cy} A ${r} ${r} 0 0 1 ${cx + r} ${cy}`}
        fill="none" stroke="#1a1f2e" strokeWidth={size * 0.07}
      />
      <path
        d={`M ${x1} ${y1} A ${r} ${r} 0 ${lg} 1 ${x2} ${y2}`}
        fill="none" stroke={color} strokeWidth={size * 0.07}
        strokeLinecap="round"
        style={{ filter: `drop-shadow(0 0 6px ${color})` }}
      />
    </svg>
  );
}

function MatrixCell({ data, isNash }) {
  if (!data) return <td style={{ border: "1px solid #1e2a3a", padding: "8px" }} />;
  const [p1, p2] = data.payoff;
  const color = p1 + p2 < -4 ? "#ff3b5c" : p1 + p2 > 5 ? "#00ff9d" : "#f5c518";
  return (
    <td style={{
      border: `1px solid ${isNash ? "#00ff9d" : "#1e2a3a"}`,
      padding: "8px 12px",
      background: isNash ? "rgba(0,255,157,0.06)" : p1 + p2 < -4 ? "rgba(255,59,92,0.08)" : "transparent",
      textAlign: "center",
      position: "relative",
    }}>
      {isNash && <span style={{ position: "absolute", top: 2, right: 4, fontSize: 9, color: "#00ff9d", fontFamily: "'Orbitron'" }}>★NE</span>}
      <span style={{ color, fontFamily: "'Share Tech Mono'", fontSize: 13 }}>
        ({p1 > 0 ? "+" : ""}{p1}, {p2 > 0 ? "+" : ""}{p2})
      </span>
    </td>
  );
}

